{
  "name": "electron-task-manager",
  "version": "1.0.0",
  "main": "main.js",
  "build": {
    "appId": "com.example.daymanager",
    "productName": "Day_Manager",
    "asarUnpack": false,
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "scripts": {
    "start": "webpack serve",
    "electron-dev": "concurrently \"npm:start\" \"wait-on http://localhost:9000 && electron .\"",
    "package": "electron-packager . Day_Manager --platform=win32 --arch=x64 --out=dist --overwrite",
    "build": "webpack",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "Madick Ange César",
  "license": "ISC",
  "description": "Manage your days with this app.",
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^4.0.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.92.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "i18next": "^23.11.5",
    "node-notifier": "^10.0.1",
    "path-browserify": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.2",
    "react-router-dom": "^6.24.0",
    "uuid": "^10.0.0"
  }
}
